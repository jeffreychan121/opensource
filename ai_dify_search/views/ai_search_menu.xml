<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- 定义动作 -->
        <record id="action_ai_search_page" model="ir.actions.client">
            <field name="name">AI 智能搜索</field>
            <field name="tag">ai_dify_search_page</field>
            <field name="target">current</field>
        </record>

        <!-- 一级菜单 -->
        <menuitem id="ai_search_menu_root"
                  name="AI 智能搜索"
                  sequence="100"/>

        <!-- 子菜单 -->
        <menuitem id="ai_search_menu"
                  name="AI 搜索"
                  parent="ai_search_menu_root"
                  action="action_ai_search_page"
                  sequence="1"/>
    </data>
</odoo>
